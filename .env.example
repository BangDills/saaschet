# =====================================================================
# DigitalOcean Serverless Inference (powers the AI chat & memory)
# =====================================================================
# Get your model access key from:
#   https://cloud.digitalocean.com  ->  Inference  ->  Model Access Keys
# Required at runtime — without it, /api/chat returns 500.
# Also used to power vector embeddings and fact extraction for user memory.
DO_INFERENCE_API_KEY=do_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Override only if DigitalOcean changes its inference base URL.
# Default: https://inference.do-ai.run/v1
# DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1

# Optional. AI SDK retries for chat inference.
# Default: 0 to avoid turning one rate-limited request into many failed attempts.
# Maximum allowed by the app: 2.
# AI_CHAT_MAX_RETRIES=0

# Optional. Agent-only visible recovery when every fallback model is rate-limited.
# Defaults: retry the current attempt once after 20 seconds. Max retries: 2.
# AI_AGENT_LIMIT_RECOVERY_RETRIES=1
# AI_AGENT_LIMIT_RECOVERY_DELAY_MS=20000

# =====================================================================
# OpenCode Zen API (free DeepSeek V4 Flash model)
# =====================================================================
# Sign up at https://opencode.ai — provides free model access.
# Without this key, the free DeepSeek model won't be available.
OPENCODE_API_KEY=

# =====================================================================
# Tavily AI (powers the in-chat web search toggle)
# =====================================================================
# Sign up at https://tavily.com — free tier gives 1000 searches/month.
# Without this key, the Web toggle still appears but is silently ignored.
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================================
# Context7 (powers up-to-date library documentation tools in chat/Agent Mode)
# =====================================================================
# Get an API key from https://context7.com/dashboard
# Without this, Context7 tools return an unavailable message.
CONTEXT7_API_KEY=ctx7sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================================
# Serena MCP (optional semantic code tools for Agent Mode)
# =====================================================================
# Run Serena as a separate MCP HTTP/SSE service and point Celiuz AI at it.
# Serena docs: https://github.com/oraios/serena
# Leave unset to disable Serena without affecting normal Agent Mode.
SERENA_MCP_URL=
# Optional bearer token if your Serena bridge is protected.
SERENA_MCP_TOKEN=
# Default false: only read-only semantic/navigation tools are allowed.
# Set true only if you explicitly want Serena write/execute tools exposed.
SERENA_ALLOW_WRITE_TOOLS=false

# =====================================================================
# Supabase (powers auth + chat history database)
# =====================================================================
# Create a free project at https://supabase.com.
# Settings -> API gives you these three values.
#
# 1. Public URL & anon key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# 2. service_role key — SECRET. Server-side only; bypasses Row Level
#    Security. Used by privileged server routes only.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================================
# GitHub (powers Agent Mode — repo read/write/PR creation)
# =====================================================================
# Create a Personal Access Token (classic) with repo scope:
#   https://github.com/settings/tokens
# Without this, Agent Mode cannot access GitHub repositories.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub OAuth App (lets users connect their GitHub account to browse repos).
# Create one at: https://github.com/settings/developers -> OAuth Apps -> New
# Callback URL: https://YOUR-DOMAIN/api/github/callback
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# =====================================================================
# Daytona (powers live sandbox execution in Agent Mode)
# =====================================================================
# Sign up at https://www.daytona.io — provides API access for sandboxes.
# Without this, Agent Mode cannot run commands or execute code.
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=https://app.daytona.io/api
# Legacy alias also supported by the app if already configured elsewhere:
# DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# Optional sandbox resource overrides (defaults: 8 CPU, 8GB RAM, 30GB disk)
# DAYTONA_SANDBOX_CPU=8
# DAYTONA_SANDBOX_MEMORY=8
# DAYTONA_SANDBOX_DISK=30
# DAYTONA_SANDBOX_IMAGE=daytonaio/ai-node:22
